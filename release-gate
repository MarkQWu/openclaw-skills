def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Release gate with read-only default checks")
    parser.add_argument(
        "--manifest",
        default="release-manifest.json",
        help="Path to release-manifest.json",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Required. Default checks inspect only; explicit smoke checks may install only inside temporary HOME.",
    )
    parser.add_argument(
        "--json-out",
        help="Optional path to write the full JSON report with complete evidence.",
    )
    parser.add_argument(
        "--check",
        "--only",
        dest="checks",
        action="append",
        help="Only report one or more check IDs. May be repeated or comma-separated.",
    )
    return parser.parse_args()


def load_manifest(path: Path) -> dict[str, Any]:
    with path.open("r", encoding="utf-8") as fh:
        return json.load(fh)


def expand(path_text: str, repo_root: Path) -> Path:
    path = Path(os.path.expanduser(path_text))
    if not path.is_absolute():
        path = repo_root / path
    return path.resolve()


def rel(path: Path, base: Path) -> str:
    try:
        return path.relative_to(base).as_posix()
    except ValueError:
        return str(path)


def read_text(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return path.read_text(encoding="utf-8", errors="replace")


def read_version(root: Path, source: str) -> str | None:
    path = root / source
    if not path.exists():
        return None
    return read_text(path).strip().splitlines()[0].strip().lstrip("v")


def first_whatsnew_version(root: Path, source: str) -> str | None:
    path = root / source
    if not path.exists():
        return None
    match = re.search(r"\*\*v?([0-9]+(?:\.[0-9]+)+)\*\*", read_text(path))
    return match.group(1) if match else None


def split_source(source: str) -> tuple[str, str | None]:
    if "#" not in source:
        return source, None
    path, anchor = source.split("#", 1)
    return path, anchor or None


def markdown_section(text: str, heading: str) -> str | None:
    lines = text.splitlines()
    start = None
    pattern = re.compile(r"^##\s+" + re.escape(heading) + r"\s*$")
    for idx, line in enumerate(lines):
        if pattern.match(line):
            start = idx + 1
            break
    if start is None:
        return None
    end = len(lines)
    for idx in range(start, len(lines)):
        if lines[idx].startswith("## "):
            end = idx
            break
    return "\n".join(lines[start:end])


def first_fenced_block(text: str) -> str | None:
    match = re.search(r"```[^\n]*\n(.*?)\n```", text, flags=re.S)
    return match.group(1) if match else None


def parse_simple_frontmatter(path: Path) -> tuple[dict[str, str], list[str]]:
    errors: list[str] = []
    if not path.exists():
        return {}, [f"missing {path}"]
    text = read_text(path)
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return {}, ["frontmatter must start with ---"]
    try:
        end = next(idx for idx in range(1, len(lines)) if lines[idx].strip() == "---")
    except StopIteration:
        return {}, ["frontmatter closing --- not found"]

    data: dict[str, str] = {}
    for line_no, line in enumerate(lines[1:end], start=2):
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if ":" not in stripped:
            errors.append(f"line {line_no}: expected key: value")
            continue
        key, raw_value = stripped.split(":", 1)
        key = key.strip()
        value = raw_value.strip()
        if not re.match(r"^[A-Za-z_][A-Za-z0-9_-]*$", key):
            errors.append(f"line {line_no}: invalid key {key!r}")
            continue
        if value.startswith('"'):
            if len(value) < 2 or not value.endswith('"'):
                errors.append(f"line {line_no}: unterminated double-quoted scalar")
                continue
            inner = value[1:-1]
            if '"' in inner.replace('\\"', ""):
                errors.append(f"line {line_no}: unescaped double quote inside double-quoted scalar")
                continue
            value = inner.replace('\\"', '"')
        elif value.startswith("'"):
            if len(value) < 2 or not value.endswith("'"):
                errors.append(f"line {line_no}: unterminated single-quoted scalar")
                continue
            value = value[1:-1].replace("''", "'")
        data[key] = value
    return data, errors


def check_frontmatter(package_root: Path, manifest: dict[str, Any]) -> list[dict[str, Any]]:
    skill_path = package_root / manifest.get("authority_sources", {}).get("skill_entrypoint", "SKILL.md")
    data, errors = parse_simple_frontmatter(skill_path)
    evidence: list[dict[str, Any]] = []
    if errors:
        evidence.append({"path": str(skill_path), "errors": errors})
    expected_name = manifest["skill"]
    if data.get("name") != expected_name:
        evidence.append({"path": str(skill_path), "field": "name", "expected": expected_name, "actual": data.get("name")})
    description = data.get("description", "")
    if not description:
        evidence.append({"path": str(skill_path), "field": "description", "error": "missing or empty"})
    elif len(description) > 1024:
        evidence.append({"path": str(skill_path), "field": "description", "error": "over 1024 chars", "length": len(description)})
    return evidence


def skill_commands(skill_text: str) -> set[str]:
    commands: set[str] = set()
    for line in skill_text.splitlines():
        match = re.match(r"^###\s+(/[^\s\[{]+)", line)
        if match:
            commands.add(match.group(1))
    return commands


def help_commands(help_block: str) -> set[str]:
    commands: set[str] = set()
    for line in help_block.splitlines():
        match = re.match(r"^(/[^\s]+)", line.strip())
        if match:
            commands.add(match.group(1))
    return commands


def check_help_source_match(package_root: Path, manifest: dict[str, Any]) -> list[dict[str, Any]]:
    help_source = manifest.get("help_source", "")
    help_path_text, anchor = split_source(help_source)
    skill_path = package_root / manifest.get("authority_sources", {}).get("skill_entrypoint", "SKILL.md")
    help_path = package_root / help_path_text
    evidence: list[dict[str, Any]] = []
    if not skill_path.exists():
        return [{"path": str(skill_path), "error": "missing SKILL.md"}]
    if not help_path.exists():
        return [{"path": str(help_path), "error": "missing help source"}]
    section = markdown_section(read_text(help_path), f"/{anchor}" if anchor and not anchor.startswith("/") else (anchor or ""))
    if section is None:
        return [{"path": str(help_path), "anchor": anchor, "error": "help section not found"}]
    block = first_fenced_block(section)
    if block is None:
        return [{"path": str(help_path), "anchor": anchor, "error": "help fenced code block not found"}]
    defined = skill_commands(read_text(skill_path))
    listed = help_commands(block)
    missing = sorted(defined - listed)
    extra = sorted(listed - defined)
    if missing or extra:
        evidence.append(
            {
                "skill": str(skill_path),
                "help_source": str(help_path),
                "missing_from_help": missing,
                "extra_in_help": extra,
            }
        )
    return evidence


def check_update_policy_repo_name(package_root: Path, manifest: dict[str, Any]) -> list[dict[str, Any]]:
    policy = manifest["repo_name_policy"]
    allowed = policy["allowed"]
    forbidden = policy.get("forbidden", [])
    update_source = package_root / manifest.get("update_mechanism_source", "references/update-mechanism.md")
    checker = package_root / manifest.get("authority_sources", {}).get("update_checker", "bin/update-check")
    evidence: list[dict[str, Any]] = []
    for path in (update_source, checker):
        if not path.exists():
            evidence.append({"path": str(path), "error": "missing"})
            continue
        text = read_text(path)
        if allowed not in text:
            evidence.append({"path": str(path), "allowed_repo": allowed, "error": "allowed repo name missing"})
        hits = [name for name in forbidden if name in text]
        if hits:
            evidence.append({"path": str(path), "forbidden": hits, "error": "forbidden repo name present"})
    return evidence


def check_skill_discovery(repo_root: Path, manifest: dict[str, Any]) -> list[dict[str, Any]]:
    evidence: list[dict[str, Any]] = []
    for package in manifest.get("distribution_repo", {}).get("package_roots", []):
        root = repo_root / package
        skill_path = root / "SKILL.md"
        if not root.exists():
            evidence.append({"package": package, "path": str(root), "error": "package root missing"})
        elif not skill_path.exists():
            evidence.append({"package": package, "path": str(skill_path), "error": "SKILL.md missing"})
    return evidence


def inline_skill_version(root: Path) -> str | None:
    skill_path = root / "SKILL.md"
    if not skill_path.exists():
        return None
    match = re.search(r"^>\s*Version:\s*v?([0-9]+(?:\.[0-9]+)+)\s*$", read_text(skill_path), flags=re.M)
    return match.group(1) if match else None


def check_sibling_version_drift(repo_root: Path, manifest: dict[str, Any]) -> list[dict[str, Any]]:
    evidence: list[dict[str, Any]] = []
    for package in manifest.get("distribution_repo", {}).get("package_roots", []):
        root = repo_root / package
        if not root.exists():
            continue
        version = read_version(root, "VERSION")
        whatsnew = first_whatsnew_version(root, "WHATSNEW.md")
        inline = inline_skill_version(root)
        if version != whatsnew:
            evidence.append(
                {
                    "package": package,
                    "root": str(root),
                    "version": version,
                    "whatsnew_first_version": whatsnew,
                    "error": "VERSION and WHATSNEW first version differ",
                }
            )
        if inline is not None and version != inline:
            evidence.append(
                {
                    "package": package,
                    "root": str(root),
                    "version": version,
                    "skill_inline_version": inline,
                    "error": "SKILL.md inline Version differs from VERSION",
                }
            )
    return evidence


def check_remake_contracts(repo_root: Path) -> list[dict[str, Any]]:
    remake_root = repo_root / "short-drama-remake"
    checker = remake_root / "scripts" / "remake_gate_checker.py"
    fixtures_root = remake_root / "references" / "fixtures"
    schema_root = remake_root / "references" / "schema"
    if not checker.exists():
        return []

    command = [sys.executable, str(checker), "--self-test"]
    for schema_path in sorted(schema_root.glob("*.yaml")):
        command.extend(["--schema", str(schema_path)])
    for fixture_path in sorted(fixtures_root.glob("*/fixture.yaml")):
        command.extend(["--fixture", str(fixture_path)])

    result = subprocess.run(
        command,
        cwd=remake_root,
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode == 0:
        return []
    return [
        {
            "checker": rel(checker, repo_root),
            "returncode": result.returncode,
            "stdout_tail": result.stdout[-2000:],
            "stderr_tail": result.stderr[-2000:],
        }
    ]


def installer_target_roots(manifest: dict[str, Any]) -> tuple[list[str], list[dict[str, str]]]:
    roots: set[str] = set()
    unresolved: list[dict[str, str]] = []
    for runtime in manifest.get("runtime_roots", []):
        if not runtime.get("required", True):
            continue
        policy = runtime.get("policy", manifest.get("runtime_policy", {}).get("default", "generated_copy"))
        if policy in {"excluded", "intentionally_excluded", "intentionally excluded by manifest"}:
            continue
        if policy in {"symlink", "declared_symlink", "declared symlink"}:
            continue

        raw = str(runtime.get("path", "")).replace("\\", "/")
        match = re.match(r"^(?:~|\$HOME|%USERPROFILE%)/(.+?)/skills/[^/]+/?$", raw)
        if match:
            roots.add(match.group(1))
            continue
        parts = PurePosixPath(raw).parts
        if "skills" in parts:
            idx = parts.index("skills")
            if idx > 0 and parts[idx - 1].startswith("."):
                roots.add(parts[idx - 1])
                continue
        unresolved.append(
            {
                "runtime": str(runtime.get("name", "unknown")),
                "path": raw,
                "error": "cannot derive installer target root from runtime path",
            }
        )
    return sorted(roots), unresolved


def check_installer_contract(repo_root: Path, manifest: dict[str, Any]) -> list[dict[str, Any]]:
    policy = manifest["repo_name_policy"]
    allowed = policy["allowed"]
    forbidden = policy.get("forbidden", [])
    installers = manifest.get("distribution_repo", {}).get("installers", [])
    if not installers:
        return []
    target_roots, target_errors = installer_target_roots(manifest)
    evidence: list[dict[str, Any]] = []
    if target_errors:
        evidence.append({"path": "release-manifest.json#runtime_roots", "errors": target_errors})
    for installer in installers:
        path = repo_root / installer
        if not path.exists():
            evidence.append({"path": str(path), "error": "installer missing"})
            continue
        text = read_text(path)
        errors: list[str] = []
        if allowed not in text:
            errors.append(f"allowed repo name {allowed!r} missing")
        for name in forbidden:
            if name in text:
                errors.append(f"forbidden repo name {name!r} present")
        if ".skill-trash" not in text:
            errors.append("safe backup root .skill-trash missing")
        if ".trash" not in text:
            errors.append("embedded skills/.trash migration missing")
        if "SKILL.md" not in text:
            errors.append("SKILL.md discovery install logic missing")
        if "short-drama/VERSION" not in text and "short-drama\\VERSION" not in text:
            errors.append("short-drama VERSION display source missing")
        if "cp -r" in text or "Copy-Item -Recurse" in text:
            errors.append("installer must link to canonical repo instead of copying skill directories")
        if "rm -rf" in text or "Remove-Item" in text:
            errors.append("destructive removal command present")
        if installer.endswith(".sh"):
            if 'for d in "$CACHE"/*/' not in text:
                errors.append("shell installer does not iterate cache package directories")
            if "ln -s" not in text:
                errors.append("shell installer does not symlink skills to the canonical repo")
            for target in target_roots:
                marker = f"$HOME/{target}"
                if marker not in text:
                    errors.append(f"shell target {marker} missing")
        elif installer.endswith(".ps1"):
            if "Get-ChildItem" not in text or "$cache" not in text:
                errors.append("PowerShell installer does not iterate cache package directories")
            if "Junction" not in text and "SymbolicLink" not in text:
                errors.append("PowerShell installer does not link skills to the canonical repo")
            for target in target_roots:
                if target not in text:
                    errors.append(f"PowerShell target {target} missing")
        if errors:
            evidence.append({"path": str(path), "errors": errors})
    return evidence


def package_roots(manifest: dict[str, Any]) -> list[str]:
    return list(manifest.get("distribution_repo", {}).get("package_roots", []))


def install_smoke_home(manifest: dict[str, Any], home: Path) -> tuple[list[str], list[dict[str, str]]]:
    roots, errors = installer_target_roots(manifest)
    for root in roots:
        owner = home / root
        skills = owner / "skills"
        skills.mkdir(parents=True, exist_ok=True)
        trash = skills / ".trash" / "legacy"
        trash.mkdir(parents=True, exist_ok=True)
        (trash / "SKILL.md").write_text(
            "---\nname: legacy-short-drama\ndescription: old trash fixture\n---\n",
            encoding="utf-8",
        )
        for package in package_roots(manifest):
            package_dir = skills / package
            package_dir.mkdir(parents=True, exist_ok=True)
            (package_dir / "SKILL.md").write_text(
                f"---\nname: {package}\ndescription: old fixture\n---\n",
                encoding="utf-8",
            )
    return roots, errors


def validate_install_smoke(manifest: dict[str, Any], home: Path, roots: list[str]) -> list[dict[str, Any]]:
    evidence: list[dict[str, Any]] = []
    packages = package_roots(manifest)
    primary = manifest["package_root"].rstrip("/").split("/")[-1]
    for root in roots:
        owner = home / root
        skills = owner / "skills"
        safe_root = owner / ".skill-trash"
        if (skills / ".trash").exists():
            evidence.append({"target": str(skills), "error": "embedded skills/.trash was not migrated"})
        if not safe_root.exists():
            evidence.append({"target": str(owner), "error": ".skill-trash was not created"})
        elif not any(path.name.startswith("from-skills-trash-") for path in safe_root.iterdir()):
            evidence.append({"target": str(safe_root), "error": "legacy skills/.trash migration backup missing"})
        for package in packages:
            package_dir = skills / package
            skill_path = package_dir / "SKILL.md"
            if not skill_path.exists():
                evidence.append({"target": str(package_dir), "error": "SKILL.md missing after install"})
            if not package_dir.is_symlink():
                evidence.append({"target": str(package_dir), "error": "skill target is not a symlink to the canonical repo"})
            elif not (package_dir.resolve() / "SKILL.md").exists():
                evidence.append({"target": str(package_dir), "error": "symlink target does not contain SKILL.md"})
            backup_prefix = f"reinstall-{package}-"
            if safe_root.exists() and not any(path.name.startswith(backup_prefix) for path in safe_root.iterdir()):
                evidence.append({"target": str(safe_root), "package": package, "error": "existing skill backup missing"})
        version_path = skills / primary / "VERSION"
        if not version_path.exists():
            evidence.append({"target": str(version_path), "error": "VERSION missing after install"})
    return evidence


def run_install_smoke(
    repo_root: Path,
    manifest: dict[str, Any],
    installer_path: Path,
    *,
    seed_local_cache: bool,
    timeout_seconds: int = 120,
) -> list[dict[str, Any]]:
    with tempfile.TemporaryDirectory(prefix="short-drama-install-smoke-") as tmp:
        home = Path(tmp) / "home"
        home.mkdir()
        roots, root_errors = install_smoke_home(manifest, home)
        if root_errors:
            return [{"path": "release-manifest.json#runtime_roots", "errors": root_errors}]

        cache = home / ".gobuildit" / "skill-repos" / manifest["canonical_repo"]["repo_name"]
        if seed_local_cache:
            cache.parent.mkdir(parents=True, exist_ok=True)
            clone = subprocess.run(
                ["git", "clone", "--quiet", str(repo_root), str(cache)],
                cwd=repo_root,
                text=True,
                capture_output=True,
                check=False,
            )
            if clone.returncode != 0:
                return [
                    {
                        "path": str(cache),
                        "error": "local cache seed failed",
                        "stderr": clone.stderr[-1000:],
                    }
                ]

        env = os.environ.copy()
        env.update(
            {
                "HOME": str(home),
                "GIT_TERMINAL_PROMPT": "0",
            }
        )
        result = subprocess.run(
            ["bash", str(installer_path)],
            cwd=repo_root,
            env=env,
            text=True,
            capture_output=True,
            timeout=timeout_seconds,
            check=False,
        )
        evidence = []
        if result.returncode != 0:
            evidence.append(
                {
                    "path": str(installer_path),
                    "returncode": result.returncode,
                    "stdout_tail": result.stdout[-1000:],
                    "stderr_tail": result.stderr[-1000:],
                    "error": "installer exited non-zero",
                }
            )
        evidence.extend(validate_install_smoke(manifest, home, roots))
        return evidence


def github_raw_url(manifest: dict[str, Any], installer: str) -> str:
    remote = manifest["canonical_repo"]["remote"]
    branch = manifest["canonical_repo"].get("branch", "main")
    match = re.match(r"https://github\.com/([^/]+)/(.+?)(?:\.git)?$", remote)
    if not match:
        raise ValueError(f"Cannot derive GitHub raw URL from remote: {remote}")
    owner, repo = match.groups()
    return f"https://raw.githubusercontent.com/{owner}/{repo}/{branch}/{installer}"


def download_external_installer(manifest: dict[str, Any], dest: Path) -> tuple[Path | None, dict[str, Any] | None]:
    installer = "install.sh"
    try:
        url = github_raw_url(manifest, installer)
    except ValueError as exc:
        return None, {"path": manifest["canonical_repo"].get("remote"), "error": str(exc)}
    try:
        with urllib.request.urlopen(url, timeout=30) as response:
            content = response.read()
    except Exception as exc:  # noqa: BLE001 - surfaced as gate evidence.
        return None, {"path": url, "error": f"download failed: {exc}"}
    path = dest / installer
    path.write_bytes(content)
    path.chmod(0o755)
    return path, None


def check_installer_local_smoke(repo_root: Path, manifest: dict[str, Any]) -> list[dict[str, Any]]:
    dirty = git_dirty_evidence(repo_root)
    if dirty:
        return dirty
    installer = repo_root / "install.sh"
    if not installer.exists():
        return [{"path": str(installer), "error": "install.sh missing"}]
    return run_install_smoke(repo_root, manifest, installer, seed_local_cache=True)


def check_external_install_smoke(repo_root: Path, manifest: dict[str, Any]) -> list[dict[str, Any]]:
    with tempfile.TemporaryDirectory(prefix="short-drama-external-installer-") as tmp:
        installer, error = download_external_installer(manifest, Path(tmp))
        if error:
            return [error]
        assert installer is not None
        return run_install_smoke(repo_root, manifest, installer, seed_local_cache=False)


def sha256(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as fh:
        for chunk in iter(lambda: fh.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def is_excluded(relpath: str, patterns: list[str]) -> bool:
    posix = PurePosixPath(relpath).as_posix()
    for pattern in patterns:
        if fnmatch.fnmatch(posix, pattern) or fnmatch.fnmatch("/" + posix, pattern):
            return True
        if pattern.endswith("/**"):
            prefix = pattern[:-3].rstrip("/")
            if posix == prefix or posix.startswith(prefix + "/"):
                return True
            if posix.endswith("/" + prefix) or ("/" + prefix + "/") in posix:
                return True
    return False


def list_files(root: Path, excluded: list[str]) -> dict[str, str]:
    files: dict[str, str] = {}
    if not root.exists():
        return files
    for path in root.rglob("*"):
        if not path.is_file():
            continue
        relpath = path.relative_to(root).as_posix()
        if is_excluded(relpath, excluded):
            continue
        files[relpath] = sha256(path)
    return files


def package_bytecode(root: Path) -> list[str]:
    hits: list[str] = []
    for path in root.rglob("*"):
        relpath = path.relative_to(root).as_posix()
        if "__pycache__" in path.parts or path.suffix == ".pyc":
            hits.append(relpath)
    return sorted(hits)


def root_doc_duplicates(root: Path, allowed: list[str]) -> list[dict[str, Any]]:
    refs = root / "references"
    if not refs.exists():
        return []
    ref_names = {path.name: path for path in refs.glob("*.md")}
    duplicates = []
    for root_doc in root.glob("*.md"):
        if root_doc.name in ref_names and root_doc.name not in allowed:
            ref_doc = ref_names[root_doc.name]
            duplicates.append(
                {
                    "path": str(root_doc),
                    "canonical_candidate": str(ref_doc),
                    "same_hash": sha256(root_doc) == sha256(ref_doc),
                }
            )
    return duplicates


def root_script_duplicates(root: Path, allowed: list[str]) -> list[dict[str, Any]]:
    scripts = root / "scripts"
    if not scripts.exists():
        return []
    script_names = {path.name: path for path in scripts.iterdir() if path.is_file()}
    duplicates = []
    for root_script in root.iterdir() if root.exists() else []:
        if not root_script.is_file() or root_script.name not in script_names:
            continue
        if root_script.name in allowed:
            continue
        if root_script.suffix in {".py", ".sh"} or os.access(root_script, os.X_OK):
            script = script_names[root_script.name]
            duplicates.append(
                {
                    "path": str(root_script),
                    "canonical_candidate": str(script),
                    "same_hash": sha256(root_script) == sha256(script),
                }
            )
    return duplicates


def update_check_split(root: Path, root_allowed: bool) -> dict[str, Any] | None:
    root_check = root / "update-check"
    bin_check = root / "bin" / "update-check"
    if root_check.exists() and bin_check.exists():
        same_hash = sha256(root_check) == sha256(bin_check)
        if not root_allowed or not same_hash:
            return {
                "root_update_check": str(root_check),
                "bin_update_check": str(bin_check),
                "same_hash": same_hash,
                "root_allowed": root_allowed,
            }
    if root_check.exists() and not root_allowed:
        return {
            "root_update_check": str(root_check),
            "bin_update_check": str(bin_check),
            "same_hash": None,
            "root_allowed": root_allowed,
        }
    return None


def scan_repo_name_drift(root: Path, scan_paths: list[str], manifest: dict[str, Any]) -> list[dict[str, Any]]:
    policy = manifest["repo_name_policy"]
    forbidden = policy.get("forbidden", [])
    hits: list[dict[str, Any]] = []
    for scan_path in scan_paths:
        path = root / scan_path
        if not path.exists() or not path.is_file():
            continue
        text = read_text(path)
        for name in forbidden:
            for line_no, line in enumerate(text.splitlines(), start=1):
                if name in line:
                    hits.append({"path": str(path), "line": line_no, "forbidden": name})
    return hits


def compare_runtime(
    package_root: Path,
    runtime: dict[str, Any],
    excluded: list[str],
    package_files: dict[str, str],
) -> dict[str, Any]:
    raw_runtime_root = Path(os.path.expanduser(runtime["path"]))
    if not raw_runtime_root.is_absolute():
        raw_runtime_root = raw_runtime_root.resolve()
    resolved_runtime_root = raw_runtime_root.resolve()
    policy = runtime.get("policy")
    status: dict[str, Any] = {
        "name": runtime["name"],
        "path": str(raw_runtime_root),
        "resolved_path": str(resolved_runtime_root),
        "policy": policy,
        "exists": raw_runtime_root.exists(),
        "symlink": raw_runtime_root.is_symlink(),
    }
    if policy in {"excluded", "intentionally_excluded", "intentionally excluded by manifest"} or runtime.get("excluded"):
        status["state"] = "intentionally excluded by manifest"
        return status

    if policy in {"symlink", "declared_symlink", "declared symlink"}:
        expected_target = runtime.get("target") or runtime.get("symlink_target")
        status["symlink_target"] = str(resolved_runtime_root) if raw_runtime_root.is_symlink() else None
        if expected_target:
            status["expected_symlink_target"] = str(Path(os.path.expanduser(expected_target)).resolve())
        target_ok = not expected_target or status["symlink_target"] == status.get("expected_symlink_target")
        if raw_runtime_root.is_symlink() and target_ok:
            status["state"] = "declared symlink"
        else:
            status["state"] = "symlink-policy-false"
        return status

    if not raw_runtime_root.exists():
        status["state"] = "missing"
        return status

    runtime_files = list_files(resolved_runtime_root, excluded)
    package_keys = set(package_files)
    runtime_keys = set(runtime_files)
    missing = sorted(package_keys - runtime_keys)
    extra = sorted(runtime_keys - package_keys)
    changed = sorted(
        relpath
        for relpath in package_keys & runtime_keys
        if package_files[relpath] != runtime_files[relpath]
    )

    status.update(
        {
            "version": read_version(resolved_runtime_root, "VERSION"),
            "files_checked": len(runtime_files),
            "missing_count": len(missing),
            "extra_count": len(extra),
            "changed_count": len(changed),
            "sample_missing": missing[:12],
            "sample_extra": extra[:12],
            "sample_changed": changed[:12],
            "state": "hash-equivalent"
            if not missing and not extra and not changed
            else "not-hash-equivalent",
        }
    )
    if policy == "canonical_symlink" and status["state"] == "hash-equivalent" and not raw_runtime_root.is_symlink():
        status["state"] = "not-canonical-symlink"
    return status


def runtime_package_specs(
    repo_root: Path,
    package_root: Path,
    manifest: dict[str, Any],
    excluded: list[str],
    primary_package_files: dict[str, str],
) -> list[dict[str, Any]]:
    specs: list[dict[str, Any]] = []
    package_roots = manifest.get("distribution_repo", {}).get("package_roots", [])
    if not package_roots:
        package_roots = [manifest["package_root"]]

    for runtime in manifest.get("runtime_roots", []):
        policy = runtime.get("policy")
        if policy in {
            "excluded",
            "intentionally_excluded",
            "intentionally excluded by manifest",
            "symlink",
            "declared_symlink",
            "declared symlink",
        }:
            runtime_package_roots = [manifest["package_root"]]
        else:
            runtime_package_roots = package_roots

        for package in runtime_package_roots:
            source_root = expand(str(package), repo_root)
            if source_root == package_root:
                source_files = primary_package_files
            else:
                source_files = list_files(source_root, excluded)

            package_name = source_root.name
            runtime_path = Path(os.path.expanduser(runtime["path"]))
            if not runtime_path.is_absolute():
                runtime_path = runtime_path.resolve()
            if policy not in {
                "excluded",
                "intentionally_excluded",
                "intentionally excluded by manifest",
                "symlink",
                "declared_symlink",
                "declared symlink",
            } and runtime_path.name != package_name:
                runtime_path = runtime_path.parent / package_name
            runtime_spec = dict(runtime)
            runtime_spec["name"] = f"{runtime.get('name', 'runtime')}:{package_name}"
            runtime_spec["path"] = str(runtime_path)
            specs.append(
                {
                    "package": package_name,
                    "package_root": source_root,
                    "package_files": source_files,
                    "runtime": runtime_spec,
                }
            )
    return specs


def finding(
    check_id: str,
    evidence: Any,
    manifest: dict[str, Any],
    severity: str = "blocking",
) -> dict[str, Any]:
    return {
        "id": check_id,
        "severity": severity,
        "description": CHECK_DESCRIPTIONS[check_id],
        "evidence": evidence,
        "recommended_next_owner": manifest.get("owners", {}).get(check_id, "release maintainer"),
    }


def selected_check_ids(raw_checks: list[str] | None) -> set[str] | None:
    if not raw_checks:
        return None
    selected: set[str] = set()
    for raw in raw_checks:
        for part in raw.split(","):
            check_id = part.strip()
            if check_id:
                selected.add(check_id)
    unknown = sorted(selected - set(CHECK_DESCRIPTIONS))
    if unknown:
        raise ValueError(f"Unknown check id(s): {', '.join(unknown)}")
    return selected


def explicit_check_selected(only_checks: set[str] | None, check_id: str) -> bool:
    return check_id in EXPLICIT_CHECKS and only_checks is not None and check_id in only_checks


def git_dirty_evidence(repo_root: Path) -> list[dict[str, Any]]:
    result = subprocess.run(
        ["git", "status", "--porcelain", "--untracked-files=all"],
        cwd=repo_root,
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        return [
            {
                "path": str(repo_root),
                "returncode": result.returncode,
                "stderr_tail": result.stderr[-1000:],
                "error": "cannot inspect git worktree status",
            }
        ]
    dirty = [line for line in result.stdout.splitlines() if line.strip()]
    if dirty:
        return [
            {
                "path": str(repo_root),
                "error": "INSTALLER_LOCAL_SMOKE seeds its cache with git clone; commit or clean worktree before running",
                "dirty_count": len(dirty),
                "sample": dirty[:10],
            }
        ]
    return []


def evidence_items(check_id: str, evidence: Any) -> list[dict[str, Any]]:
    if check_id == "BYTECODE_IN_PACKAGE" and isinstance(evidence, dict):
        root = evidence.get("root")
        return [{"root": root, "path": path} for path in evidence.get("paths", [])]

    if check_id in {"DUPLICATE_AUTHORITY_DOCS", "DUPLICATE_AUTHORITY_SCRIPTS"}:
        items: list[dict[str, Any]] = []
        for group in evidence if isinstance(evidence, list) else []:
            root = group.get("root")
            for duplicate in group.get("duplicates", []):
                items.append({"root": root, **duplicate})
        return items

    if isinstance(evidence, list):
        return [item if isinstance(item, dict) else {"value": item} for item in evidence]
    if isinstance(evidence, dict):
        return [evidence]
    return [{"value": evidence}]


def compact_finding(item: dict[str, Any], sample_size: int = 10) -> dict[str, Any]:
    items = evidence_items(item["id"], item.get("evidence"))
    return {
        "id": item["id"],
        "severity": item["severity"],
        "description": item["description"],
        "evidence_summary": {
            "count": len(items),
            "sample_size": min(len(items), sample_size),
            "truncated": max(0, len(items) - sample_size),
            "sample": items[:sample_size],
        },
        "recommended_next_owner": item["recommended_next_owner"],
    }


def compact_report(report: dict[str, Any]) -> dict[str, Any]:
    compact = dict(report)
    compact["blocking_findings"] = [
        compact_finding(item) for item in report["blocking_findings"]
    ]
    compact["nonblocking_findings"] = [
        compact_finding(item) for item in report["nonblocking_findings"]
    ]
    compact["evidence_mode"] = {
        "stdout": "summary",
        "json_out": "full evidence when --json-out is provided",
    }
    return compact


def main() -> int:
    args = parse_args()
    if not args.dry_run:
        print("release-gate is read-only in Phase 3; pass --dry-run.", file=sys.stderr)
        return 1
    try:
        only_checks = selected_check_ids(args.checks)
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 1

    manifest_path = Path(args.manifest).resolve()
    repo_root = manifest_path.parent
    manifest = load_manifest(manifest_path)
    package_root = expand(manifest["package_root"], repo_root)
    excluded = manifest.get("excluded_paths", [])
    version_source = manifest.get("version_source", "VERSION")
    whatsnew_source = manifest.get("whatsnew_source", "WHATSNEW.md")

    package_version = read_version(package_root, version_source)
    package_files = list_files(package_root, excluded)

    findings: list[dict[str, Any]] = []

    frontmatter_evidence = check_frontmatter(package_root, manifest)
    if frontmatter_evidence:
        findings.append(finding("FRONTMATTER_PARSE", frontmatter_evidence, manifest))

    help_evidence = check_help_source_match(package_root, manifest)
    if help_evidence:
        findings.append(finding("HELP_SOURCE_MATCH", help_evidence, manifest))

    update_policy_evidence = check_update_policy_repo_name(package_root, manifest)
    if update_policy_evidence:
        findings.append(finding("UPDATE_POLICY_REPO_NAME", update_policy_evidence, manifest))

    skill_discovery_evidence = check_skill_discovery(repo_root, manifest)
    if skill_discovery_evidence:
        findings.append(finding("SKILL_DISCOVERY", skill_discovery_evidence, manifest))

    sibling_version_drift_evidence = check_sibling_version_drift(repo_root, manifest)
    if sibling_version_drift_evidence:
        findings.append(finding("SIBLING_VERSION_DRIFT", sibling_version_drift_evidence, manifest))

    remake_contract_evidence = check_remake_contracts(repo_root)
    if remake_contract_evidence:
        findings.append(finding("REMAKE_CONTRACTS", remake_contract_evidence, manifest))

    installer_contract_evidence = check_installer_contract(repo_root, manifest)
    if installer_contract_evidence:
        findings.append(finding("INSTALLER_CONTRACT", installer_contract_evidence, manifest))

    if explicit_check_selected(only_checks, "INSTALLER_LOCAL_SMOKE"):
        local_smoke_evidence = check_installer_local_smoke(repo_root, manifest)
        if local_smoke_evidence:
            findings.append(finding("INSTALLER_LOCAL_SMOKE", local_smoke_evidence, manifest))

    if explicit_check_selected(only_checks, "EXTERNAL_INSTALL_SMOKE"):
        external_smoke_evidence = check_external_install_smoke(repo_root, manifest)
        if external_smoke_evidence:
            findings.append(finding("EXTERNAL_INSTALL_SMOKE", external_smoke_evidence, manifest))

    bytecode_hits = package_bytecode(package_root)
    if bytecode_hits:
        findings.append(
            finding(
                "BYTECODE_IN_PACKAGE",
                {"root": str(package_root), "paths": bytecode_hits},
                manifest,
            )
        )

    wrappers = manifest.get("allowed_wrappers", {})
    roots_to_check = [{"name": "package", "path": str(package_root)}]
    roots_to_check.extend(manifest.get("runtime_roots", []))

    duplicate_doc_evidence = []
    duplicate_script_evidence = []
    update_split_evidence = []
    whatsnew_mismatch_evidence = []
    version_drift_evidence = []
    runtime_statuses = []
    runtime_policy_evidence = []
    sibling_missing_evidence = []

    for root_info in roots_to_check:
        root = Path(os.path.expanduser(root_info["path"])).resolve()
        if not root.exists():
            continue
        if root_info.get("name") == "package":
            docs = root_doc_duplicates(root, wrappers.get("root_docs", []))
            if docs:
                duplicate_doc_evidence.append({"root": str(root), "duplicates": docs})
            scripts = root_script_duplicates(root, wrappers.get("root_scripts", []))
            if scripts:
                duplicate_script_evidence.append({"root": str(root), "duplicates": scripts})
            split = update_check_split(root, bool(wrappers.get("root_update_check", False)))
            if split:
                update_split_evidence.append({"root": str(root), **split})
        root_version = read_version(root, version_source)
        root_whatsnew_version = first_whatsnew_version(root, whatsnew_source)
        if root_version != root_whatsnew_version:
            whatsnew_mismatch_evidence.append(
                {
                    "root": str(root),
                    "version": root_version,
                    "whatsnew_first_version": root_whatsnew_version,
                }
            )
        if root_info.get("name") != "package" and root_version != package_version:
            version_drift_evidence.append(
                {
                    "runtime": root_info.get("name"),
                    "path": str(root),
                    "runtime_version": root_version,
                    "package_version": package_version,
                }
            )

    if duplicate_doc_evidence:
        findings.append(finding("DUPLICATE_AUTHORITY_DOCS", duplicate_doc_evidence, manifest))
    if duplicate_script_evidence:
        findings.append(finding("DUPLICATE_AUTHORITY_SCRIPTS", duplicate_script_evidence, manifest))
    if update_split_evidence:
        findings.append(finding("UPDATE_CHECK_SPLIT", update_split_evidence, manifest))
    if whatsnew_mismatch_evidence:
        findings.append(finding("WHATSNEW_MISMATCH", whatsnew_mismatch_evidence, manifest))
    if version_drift_evidence:
        findings.append(finding("VERSION_DRIFT", version_drift_evidence, manifest))

    repo_name_hits = scan_repo_name_drift(
        repo_root,
        manifest["repo_name_policy"].get("scan_paths", []),
        manifest,
    )
    if repo_name_hits:
        findings.append(finding("UPDATE_REPO_NAME_DRIFT", repo_name_hits, manifest))

    for spec in runtime_package_specs(repo_root, package_root, manifest, excluded, package_files):
        status = compare_runtime(
            spec["package_root"],
            spec["runtime"],
            excluded,
            spec["package_files"],
        )
        status["package"] = spec["package"]
        runtime_statuses.append(status)
        allowed_states = set(manifest.get("runtime_policy", {}).get("allowed_states", ["hash-equivalent"]))
        if status["state"] not in allowed_states:
            runtime_policy_evidence.append(status)

    for runtime in manifest.get("runtime_roots", []):
        runtime_root = Path(os.path.expanduser(runtime["path"])).resolve()
        for sibling in manifest.get("sibling_skills", []):
            if not sibling.get("runtime_required", False):
                continue
            sibling_root = runtime_root.parent / sibling["name"]
            if not sibling_root.exists():
                sibling_missing_evidence.append(
                    {
                        "runtime": runtime["name"],
                        "expected": str(sibling_root),
                        "required_for": sibling.get("required_for", []),
                    }
                )

    for sibling in manifest.get("sibling_skills", []):
        sibling_package = repo_root / sibling["name"]
        if not sibling_package.exists():
            sibling_missing_evidence.append(
                {
                    "runtime": "distribution",
                    "expected": str(sibling_package),
                    "required_for": sibling.get("required_for", []),
                }
            )

    if runtime_policy_evidence:
        findings.append(finding("RUNTIME_POLICY_FALSE", runtime_policy_evidence, manifest))
    if sibling_missing_evidence:
        findings.append(finding("SIBLING_MISSING", sibling_missing_evidence, manifest))
    if only_checks is not None:
        findings = [item for item in findings if item["id"] in only_checks]

    blocking = [item for item in findings if item["severity"] == "blocking"]
    status = "fail" if blocking else "pass"
    report = {
        "schema_version": "1.0",
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "dry_run": True,
        "status": status,
        "package": {
            "name": manifest["skill"],
            "version": package_version,
            "canonical_repo": str(repo_root),
            "package_root": str(package_root),
            "files_checked": len(package_files),
        },
        "runtime_roots": runtime_statuses,
        "blocking_findings": blocking,
        "nonblocking_findings": [item for item in findings if item["severity"] != "blocking"],
        "summary": {
            "blocking_count": len(blocking),
            "checks_failed": sorted({item["id"] for item in blocking}),
            "checks_selected": sorted(only_checks) if only_checks is not None else None,
            "message": "release gate failed" if blocking else "release gate passed",
        },
    }

    rendered = json.dumps(compact_report(report), ensure_ascii=False, indent=2)
    print(rendered)
    if args.json_out:
        full_rendered = json.dumps(report, ensure_ascii=False, indent=2)
        Path(args.json_out).write_text(full_rendered + "\n", encoding="utf-8")

    print("", file=sys.stderr)
    print("Release gate dry-run summary", file=sys.stderr)
    print(f"- status: {status}", file=sys.stderr)
    print(f"- package: {manifest['skill']} v{package_version}", file=sys.stderr)
    print(f"- canonical: {repo_root}", file=sys.stderr)
    if only_checks is not None:
        print(f"- selected checks: {', '.join(sorted(only_checks))}", file=sys.stderr)
    print(f"- blocking findings: {len(blocking)}", file=sys.stderr)
    for item in blocking:
        count = compact_finding(item)["evidence_summary"]["count"]
        print(f"  - {item['id']} ({count} evidence): {item['recommended_next_owner']}", file=sys.stderr)

    return 2 if blocking else 0


if __name__ == "__main__":
    raise SystemExit(main())
